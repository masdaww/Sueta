# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Модель ИИ (необязательно, по умолчанию openai-fast)
# Бесплатный no-key провайдер Pollinations сейчас поддерживает openai-fast/openai
# AI_MODEL=openai-fast
# AI_FALLBACK_MODEL=openai

# Системный промпт для ИИ (необязательно)
# SYSTEM_PROMPT=Ты — дружелюбный и умный ИИ-ассистент. Отвечай кратко, по делу и на русском языке.
