# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Основной быстрый AI-провайдер: Google Gemini
# Получить бесплатно: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-flash-latest

# Fallback без API-ключей: Pollinations AI
AI_MODEL=openai-fast
AI_FALLBACK_MODEL=openai

# Системный промпт для ИИ (необязательно)
# SYSTEM_PROMPT=Ты — дружелюбный и умный ИИ-ассистент. Отвечай кратко, по делу и на русском языке.
